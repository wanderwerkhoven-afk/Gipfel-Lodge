rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if the authenticated user exists in the 'users' collection
    // Both 'superuser' and 'user' roles get access to manage the dashboard.
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // [USERS] Only user themselves can read their profile; superuser has full access.
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // [PRICING & SETTINGS] Public can read for calculation; only Admin can edit.
    match /pricing_versions/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /discount_presets/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /scheduled_discounts/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // [METADATA] Counters for sequential IDs (e.g. Booking Numbers)
    match /metadata/counters {
      allow read, write: if true; 
    }

    // [BOOKINGS] Private collection with PII. Public can only create new requests.
    // Admins can create bookings with any status (needed for Excel import of owner-stays etc.)
    match /bookings/{bookingId} {
      allow create: if isAdmin() || (true && request.resource.data.status == 'pending');
      allow read, update, delete: if isAdmin();
    }

    // [PUBLIC AVAILABILITY] No PII. Public can read and create pending requests.
    match /public_availability/{availId} {
      allow read: if true;
      allow create: if (true && request.resource.data.status == 'pending') || isAdmin();
      allow update, delete: if isAdmin();
    }

    // [LOGS] Only Admin can interact with audit logs.
    match /audit_logs/{logId} {
      allow read, write: if isAdmin();
    }

    // [ANALYTICS] Public can log views; only Admin can read/manage.
    match /page_views/{viewId} {
      allow create: if true;
      allow read, delete: if isAdmin();
    }

    // [TODOS] Users can read/write their own todo list. Admins can read/write all.
    match /todos/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // [SYSTEM CHECKS] Publicly accessible for health checks
    match /system_checks/{checkId} {
      allow read, write: if true;
    }

    // DEFAULT: Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
