<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Bestaande bestanden en mappen normaal blijven laden
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Laat de geldige SPA-routes door de frontend afhandelen
  RewriteRule ^(home|lodge|activities|enjoyment|booking)(?:/.*)?$ /index.html [L]
</IfModule>
