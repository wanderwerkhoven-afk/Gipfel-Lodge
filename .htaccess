# =====================================================================
# GIPFEL LODGE - SPA ROUTING CONFIGURATIE
# =====================================================================
# OPMERKING: gipfellodge.nl / .de / .eu zijn ingesteld als Parked Domains
# in SiteGround. SiteGround verwerkt die domein-redirects zelf (server-level),
# vóórdat Apache/.htaccess in actie komt. HTTP_HOST-based redirects hier
# zouden dus nooit getriggerd worden en zijn daarom weggelaten.
# =====================================================================

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # -------------------------------------------------------------------
  # SPA ROUTING & REWRITES VOOR TAALPADEN
  # -------------------------------------------------------------------

  # Sla bestaande fysieke bestanden en mappen over (assets, CSS, JS, etc.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Rewrite alle taalpaden (/de/*, /nl/*, /en/*) naar index.html voor SPA routing
  RewriteRule ^(de|nl|en)(/.*)?$ index.html [L]
</IfModule>
